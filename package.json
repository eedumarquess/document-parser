{
  "name": "document-parser",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "build": "tsc -b packages/shared-kernel/tsconfig.json packages/document-processing-domain/tsconfig.json packages/shared-infrastructure/tsconfig.json packages/testkit/tsconfig.json apps/orchestrator-api/tsconfig.json apps/document-processing-worker/tsconfig.json --force",
    "build:api": "corepack pnpm --filter @document-parser/orchestrator-api build",
    "build:worker": "corepack pnpm --filter @document-parser/document-processing-worker build",
    "dev:api": "corepack pnpm run build:api && node apps/orchestrator-api/dist/src/main.js",
    "dev:worker": "corepack pnpm run build:worker && node apps/document-processing-worker/dist/src/main.js",
    "docker:dev:bootstrap": "node tooling/scripts/docker-dev-bootstrap.cjs",
    "docker:dev:api": "node tooling/scripts/docker-dev-runner.cjs api",
    "docker:dev:worker": "node tooling/scripts/docker-dev-runner.cjs worker",
    "lint": "eslint .",
    "typecheck": "tsc -b packages/shared-kernel/tsconfig.json packages/document-processing-domain/tsconfig.json packages/shared-infrastructure/tsconfig.json packages/testkit/tsconfig.json apps/orchestrator-api/tsconfig.json apps/document-processing-worker/tsconfig.json --force --pretty false",
    "test": "node tooling/scripts/run-all-tests.cjs",
    "test:domain": "jest --config jest.workspace.config.cjs --selectProjects orchestrator-domain worker-domain --silent",
    "test:application": "jest --config jest.workspace.config.cjs --selectProjects orchestrator-application worker-application --silent",
    "test:contracts": "jest --config jest.workspace.config.cjs --selectProjects orchestrator-contracts worker-contracts --silent",
    "test:e2e": "jest --config jest.workspace.config.cjs --selectProjects orchestrator-e2e worker-e2e --silent"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/amqplib": "^0.10.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.23.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "testcontainers": "^10.24.1",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  }
}
