DOCUMENT_PARSER_RUNTIME_MODE=real
MONGODB_URI=mongodb://localhost:27017/document-parser
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_PROCESSING_REQUESTED=document-processing.requested
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET_ORIGINALS=document-parser-originals
OBSERVABILITY_MODE=local
PDFINFO_BINARY=pdfinfo
PDFTOPPM_BINARY=pdftoppm
TESSERACT_BINARY=tesseract
TESSERACT_LANGUAGE=por

# Optional OTLP settings
